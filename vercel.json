{
    "functions": {
        "api/**/*.php": {
            "runtime": "vercel-php@0.9.0"
        }
    },
    "rewrites": [
        {
            "source": "/api/set_webhook.php",
            "destination": "/api/set_webhook.php"
        },
        {
            "source": "/(.*)",
            "destination": "/api/index.php"
        }
    ]
}
